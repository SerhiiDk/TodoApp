@page "/"
@inject TodoApp.Services.TodoService TodoService

<PageTitle>Todo App</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Todo List</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudTextField @bind-Value="newTitle"
                      Placeholder="New task..."
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Edit"
                      OnKeyDown="OnKeyDown"
                      FullWidth="true"
                      Margin="Margin.Dense" />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="AddTodo"
                   Disabled="@string.IsNullOrWhiteSpace(newTitle)">
            Add
        </MudButton>
    </MudStack>
</MudPaper>

@{
    var todos = TodoService.GetAll();
}

@if (!todos.Any())
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        No tasks yet. Add one above!
    </MudAlert>
}
else
{
    var pending = todos.Count(t => !t.IsCompleted);
    var completed = todos.Count(t => t.IsCompleted);

    <MudStack Row="true" Spacing="2" Class="mb-4">
        <MudChip T="string" Icon="@Icons.Material.Filled.PendingActions" Color="Color.Warning">@pending pending</MudChip>
        <MudChip T="string" Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success">@completed done</MudChip>
    </MudStack>

    <MudPaper Elevation="2">
        <MudList T="string" Dense="true">
            @foreach (var item in todos)
            {
                <MudListItem T="string">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width:100%">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudCheckBox T="bool" @bind-Checked="item.IsCompleted"
                                         Color="Color.Primary" />
                            <MudText Style="@(item.IsCompleted ? "text-decoration:line-through; opacity:0.6;" : "")">
                                @item.Title
                            </MudText>
                        </MudStack>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="() => Delete(item.Id)"
                                       aria-label="Delete task" />
                    </MudStack>
                </MudListItem>
                <MudDivider />
            }
        </MudList>
    </MudPaper>

    @if (completed > 0)
    {
        <MudButton Class="mt-3"
                   Variant="Variant.Outlined"
                   Color="Color.Error"
                   StartIcon="@Icons.Material.Filled.DeleteSweep"
                   OnClick="ClearCompleted">
            Clear completed
        </MudButton>
    }
}

@code {
    private string newTitle = string.Empty;

    private void AddTodo()
    {
        TodoService.Add(newTitle);
        newTitle = string.Empty;
    }

    private void Delete(int id) => TodoService.Delete(id);

    private void ClearCompleted()
    {
        foreach (var item in TodoService.GetAll().Where(t => t.IsCompleted).ToList())
            TodoService.Delete(item.Id);
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddTodo();
    }
}
