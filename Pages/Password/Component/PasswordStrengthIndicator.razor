<MudStack Spacing="1">
    <MudText Typo="Typo.caption" Color="@_labelColor">
        Password strength: <strong>@_label</strong>
    </MudText>
    <MudProgressLinear Value="@_progress"
                       Color="@_barColor"
                       Rounded="true"
                       Size="Size.Small" />
</MudStack>

@code {
    [Parameter] public string Password { get; set; } = string.Empty;

    private string _label = "None";
    private Color _labelColor = Color.Default;
    private Color _barColor = Color.Default;
    private double _progress;

    protected override void OnParametersSet()
    {
        (_label, _labelColor, _barColor, _progress) = EvaluateStrength(Password);
    }

    private static (string label, Color labelColor, Color barColor, double progress) EvaluateStrength(string password)
    {
        if (string.IsNullOrEmpty(password))
            return ("None", Color.Default, Color.Default, 0);

        int score = 0;

        if (password.Length >= 8)  score++;
        if (password.Length >= 12) score++;
        if (password.Any(char.IsUpper)) score++;
        if (password.Any(char.IsDigit)) score++;
        if (password.Any(c => !char.IsLetterOrDigit(c))) score++;

        return score switch
        {
            <= 1 => ("Weak",   Color.Error,   Color.Error,   33),
            <= 3 => ("Fair",   Color.Warning, Color.Warning, 66),
            _    => ("Strong", Color.Success, Color.Success, 100),
        };
    }
}
